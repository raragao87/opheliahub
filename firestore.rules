rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for better security
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUserData() {
      // Ensure no sensitive fields are being written that shouldn't be
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    // User profile and data collections
    match /users/{userId} {
      // User profile documents
      match /profile/{profileId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      // Financial data
      match /accounts/{accountId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /transactionSplits/{splitId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /transactionLinks/{linkId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      // Budget data
      match /budgets/{budgetId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /budgetItems/{budgetItemId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      // Categories and tags
      match /categories/{categoryId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /subcategories/{subcategoryId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /tags/{tagId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      match /deletedTags/{deletedTagId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      // Account types and configuration
      match /accountTypes/{accountTypeId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      // Growth tracking
      match /growthRecords/{recordId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
      
      // Hierarchy data
      match /hierarchy/{hierarchyId} {
        allow read, write: if isOwner(userId) && isValidUserData();
      }
    }
    
    // Shared profiles for family accounts
    match /sharedProfiles/{profileId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.sharedWith[request.auth.uid] != null || 
         resource.data.ownerId == request.auth.uid);
      
      // Allow creation only by owner
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid &&
        isValidUserData();
    }
    
    // Sharing invitations
    match /sharingInvitations/{invitationId} {
      // Users can read invitations where they are the invitee or inviter
      allow read: if isAuthenticated() && 
        (resource.data.inviteeEmail == request.auth.token.email ||
         resource.data.inviterId == request.auth.uid);
         
      // Users can create invitations they send
      allow create: if isAuthenticated() &&
        request.resource.data.inviterId == request.auth.uid &&
        isValidUserData();
        
      // Users can update invitations they receive or send
      allow update: if isAuthenticated() &&
        (resource.data.inviteeEmail == request.auth.token.email ||
         resource.data.inviterId == request.auth.uid) &&
        isValidUserData();
        
      // Users can delete invitations they send
      allow delete: if isAuthenticated() &&
        resource.data.inviterId == request.auth.uid;
    }
  }
}